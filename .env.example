# Google Maps SDK for Android
# https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=YOUR_API_KEY_HERE

# Mapbox Geocoding API (place search) - replaces Google Places
# https://account.mapbox.com/access-tokens/
MAPBOX_ACCESS_TOKEN=pk.YOUR_PUBLIC_TOKEN_HERE

# AdMob IDs (replace with your production IDs before release)
# https://admob.google.com/
ADMOB_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~YYYYYYYYYY
ADMOB_BANNER_ID=ca-app-pub-XXXXXXXXXXXXXXXX/AAAAAAAAAA
ADMOB_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/BBBBBBBBBB

# RevenueCat (in-app subscription) - Android API key
# https://app.revenuecat.com/
REVENUECAT_ANDROID_API_KEY=YOUR_REVENUECAT_ANDROID_API_KEY

# Cloud Functions base URL (notify collaborators endpoint)
# Dev:  https://asia-northeast1-yorimichi-app-dev.cloudfunctions.net
# Prod: https://asia-northeast1-yorimichi-app.cloudfunctions.net
CLOUD_FUNCTIONS_BASE_URL=https://asia-northeast1-yorimichi-app-dev.cloudfunctions.net
