rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 共有メモ ──────────────────────────────────────────────────────────────
    // shareId を知っている認証済みユーザーのみアクセス可能
    match /sharedMemos/{shareId} {
      // 読み取り: 認証済みであれば誰でも可（shareId を知っている前提）
      allow read: if request.auth != null;

      // 新規作成: 認証済みユーザーのみ。必須フィールドの存在を検証
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['title', 'items', 'ownerDeviceId', 'collaborators', 'updatedAt'])
        && request.resource.data.collaborators.size() <= 21
        && request.resource.data.items.size() <= 100;

      // 更新: 認証済みかつ collaborators に含まれるデバイスのみ
      // ownerDeviceId の書き換えは禁止
      allow update: if request.auth != null
        && request.resource.data.ownerDeviceId == resource.data.ownerDeviceId
        && request.resource.data.collaborators.size() <= 21
        && request.resource.data.items.size() <= 100;

      // 削除: 認証済みユーザーのみ（将来的に ownerUid ベースに移行予定）
      // TODO: ownerUid フィールド追加後、resource.data.ownerUid == request.auth.uid に変更
      allow delete: if request.auth != null;
    }

    // ── クーポンコード ────────────────────────────────────────────────────────
    // 書き込みは「used: false → true」のみ許可（トランザクションで使用）
    match /couponCodes/{code} {
      // 読み取り: 認証済みユーザーのみ（コードの有効性確認用）
      allow read: if request.auth != null;

      // 作成・削除: クライアントから不可（Firebase Console / Admin SDK のみ）
      allow create, delete: if false;

      // 更新: used フラグを false → true に変更する場合のみ許可
      allow update: if request.auth != null
        && request.resource.data.used == true
        && resource.data.used == false
        && request.resource.data.keys().hasOnly(resource.data.keys());
    }

    // ── クラウドバックアップ（プレミアム機能）──────────────────────────────────
    // ownerUid で所有者を検証し、自分のバックアップのみアクセス可能
    match /backups/{deviceId} {
      // 新規作成: ownerUid が自分の UID と一致すること
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;

      // 読み取り・更新・削除: 既存ドキュメントの ownerUid が自分の UID と一致すること
      allow read, update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    // その他のコレクションはすべて拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
